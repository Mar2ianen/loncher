# Development logging
RUST_LOG=loncher=debug,loncher_runtime=debug,info

# Optional override. Default: $XDG_RUNTIME_DIR/loncher/loncher.sock
LONCHER_SOCKET=

# AI providers — leave empty until the agent phase
CEREBRAS_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# MCP/connectors
EXA_API_KEY=

# Optional integrations
MAXMIND_DB_PATH=
WEATHER_API_KEY=
