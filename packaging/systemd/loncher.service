[Unit]
Description=loncher desktop control plane daemon
Documentation=https://github.com/Mar2ianen/loncher
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/loncher daemon
EnvironmentFile=-%h/.config/loncher/environment
Restart=on-failure
RestartSec=1s
TimeoutStopSec=5s

[Install]
WantedBy=default.target
